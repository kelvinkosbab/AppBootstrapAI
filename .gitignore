# ---------------------------------------------------------------------------
# Recommended ignores for Apple-platform app projects (Xcode, Swift, SPM,
# CocoaPods, Carthage, fastlane). Uncomment or keep as a reference for apps
# that adopt this bootstrap.
# ---------------------------------------------------------------------------

# Xcode — user-specific files
*xcuserdata*
*.xcuserstate
*.xcuserdatad
*.xcscmblueprint
*.xccheckout

# Xcode — build artifacts
DerivedData/
build/
*.moved-aside
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# Swift Package Manager
.build/
.swiftpm/
Package.resolved
Packages/
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/

# CocoaPods (uncomment if the project uses CocoaPods)
# Pods/
# *.xcworkspace

# Carthage
Carthage/Build/
Carthage/Checkouts/

# fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# Playgrounds
timeline.xctimeline
playground.xcworkspace

# IDE files
.idea/
*.iml

